# ═══════════════════════════════════════════════════════════════
#  Watch Party — Docker Environment Variables Template
#  Copy to docker/.env and fill in real values.
#  NEVER commit docker/.env to version control.
# ═══════════════════════════════════════════════════════════════

# Backend port (host-side)
BACKEND_PORT=8000

# All backend settings (passed to the container via env_file)
# See backend/.env.example for full documentation

# ── Database (Supabase PostgreSQL) ───────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.YOURPROJECT:YOURPASSWORD@aws-0-YOURREGION.pooler.supabase.com:5432/postgres

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME
HLS_KEY_SIGNING_SECRET=CHANGE_ME

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── External APIs ─────────────────────────────────────────────
TMDB_API_KEY=
OMDB_API_KEY=
